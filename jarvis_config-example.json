    {
      "name": "query_stock_price",
      "description": "查詢台股即時股價",
      "parameters": {
        "type": "object",
        "properties": {
          "stock_id": {"type": "string", "description": "股票代號如 2330"},
          "days": {"type": "integer", "description": "查詢天數"}
        },
        "required": ["stock_id"]
      },
      "command": "/opt/homebrew/bin/python3.11 -c \"from skills.finmind_tool import taiwan_stock_price; print(taiwan_stock_price('{stock_id}', {days}))\""
    }
  ]
